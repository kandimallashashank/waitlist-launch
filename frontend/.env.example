# ── Server-only (Vercel / .env.local) — never prefix with NEXT_PUBLIC ──
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
# Alternative name (same as apps/api):
# SUPABASE_SERVICE_KEY=

RESEND_API_KEY=
RESEND_FROM_EMAIL=ScentRev <onboarding@yourdomain.com>


# ── Public (browser) — catalog marquee + store links ──
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_STORE_URL=https://scentrev.com
NEXT_PUBLIC_WAITLIST_ONLY=true

# Bottle marquee: use bundled catalog (Supabase-sourced URLs in lib/waitlist/staticCatalog.ts).
# Set to "false" to load from NEXT_PUBLIC_API_URL instead.
# NEXT_PUBLIC_WAITLIST_USE_STATIC_CATALOG=false

# Optional: R2 hostname for image proxy (see lib/imageProxy.ts)
# NEXT_PUBLIC_R2_IMAGE_HOSTNAME=
